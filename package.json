{
  "name": "time-tracker",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted multi-tenant time tracker (web + Chrome extension)",
  "packageManager": "pnpm@11.0.4",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --stream dev",
    "build": "pnpm -r --filter=!./apps/extension build && pnpm --filter ./apps/extension build",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --workspace-concurrency=1 test",
    "test:watch": "vitest",
    "test:trace": "tsx scripts/test-trace.ts",
    "test:e2e": "pnpm --filter ./apps/web test:e2e",
    "test:e2e:ext": "pnpm --filter ./apps/extension test:e2e",
    "test:all": "pnpm lint && pnpm typecheck && pnpm test && pnpm test:trace",
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "db:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "db:reset": "docker compose -f docker-compose.dev.yml down -v && docker compose -f docker-compose.dev.yml up -d",
    "prisma:generate": "pnpm --filter @tt/db prisma:generate",
    "prisma:migrate": "pnpm --filter @tt/db prisma:migrate",
    "prisma:seed": "pnpm --filter @tt/db prisma:seed",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
