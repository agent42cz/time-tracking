{
  "name": "@tt/extension",
  "version": "1.5.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:publish": "vite build && node scripts/strip-dev-manifest.mjs && cd dist && zip -r ../time-tracker-extension-v$npm_package_version.zip .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "icons": "node scripts/render-icons.mjs",
    "screenshot": "node scripts/render-store-screenshot.mjs"
  },
  "dependencies": {
    "@tt/shared": "workspace:*",
    "@tt/ui": "workspace:*",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/chrome": "^0.0.287",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.13",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
