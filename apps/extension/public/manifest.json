{
  "manifest_version": 3,
  "name": "Time Tracker",
  "description": "Self-hostovaný time tracker — synchronizuje se s webovou aplikací Agent42.",
  "version": "1.4.0",
  "icons": {
    "16": "icons/icon-16-idle.png",
    "32": "icons/icon-32-idle.png",
    "48": "icons/icon-48-idle.png",
    "128": "icons/icon-128-idle.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Time Tracker",
    "default_icon": {
      "16": "icons/icon-16-idle.png",
      "32": "icons/icon-32-idle.png",
      "48": "icons/icon-48-idle.png",
      "128": "icons/icon-128-idle.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage", "alarms"],
  "host_permissions": ["http://localhost:3000/*", "https://*.agent42.cz/*"],
  "externally_connectable": {
    "matches": ["http://localhost:3000/*", "https://*.agent42.cz/*"]
  }
}
