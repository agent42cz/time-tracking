# Copy to .env for local development.
# Local stack ports come from docker-compose.dev.yml (Postgres 5433, Redis 6380, MailHog 1025).

# Database
DATABASE_URL=postgresql://timetracker:timetracker@localhost:5433/timetracker?schema=public

# Redis (real-time sync pub/sub)
REDIS_URL=redis://localhost:6380

# Auth.js
AUTH_SECRET=replace-me-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# SMTP (MailHog locally)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@time-tracker.local

# WebSocket service
WS_PORT=3001
WS_PUBLIC_URL=ws://localhost:3001

# App
APP_URL=http://localhost:3000
NODE_ENV=development

# Backups (Phase 10)
BACKUP_DESTINATION=/backups
BACKUP_RETENTION_DAYS=14

# Shared secret for POST /api/cron/purge. Generate with `openssl rand -hex 32`.
CRON_SECRET=
